# ==============================================
# CRM INMOBILIARIO PROFESIONAL — Variables de Entorno
# Copia este archivo como .env y rellena tus valores
# ==============================================

# --- Base de Datos ----------------------------------------
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=cambia_esto_en_produccion
POSTGRES_DB=crm_inmobiliario
DATABASE_URL=postgresql://crm_user:cambia_esto_en_produccion@localhost:5432/crm_inmobiliario

# --- Seguridad -------------------------------------------
JWT_SECRET=genera_una_cadena_aleatoria_larga_aqui
NODE_ENV=development

# --- Google OAuth 2.0 ------------------------------------
# Obtén en: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# --- Google Drive API v3 ---------------------------------
# Carpeta raíz del CRM en Drive (obtén el ID de la URL de Drive)
GOOGLE_DRIVE_FOLDER_ID=id_de_la_carpeta_raiz_en_drive

# --- Google Sheets API v4 --------------------------------
GOOGLE_SHEETS_VACACIONAL_ID=id_del_sheet_alquiler_vacacional
GOOGLE_SHEETS_LARGA_DURACION_ID=id_del_sheet_alquiler_larga_duracion
GOOGLE_SHEETS_VENTA_ID=id_del_sheet_venta
GOOGLE_SHEETS_PROPIETARIOS_ID=id_del_sheet_propietarios
GOOGLE_SHEETS_CLIENTES_ID=id_del_sheet_clientes

# Path al archivo JSON de credenciales de la Service Account de Google
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/google-service-account.json

# --- OpenAI (Módulo IA Documental) -----------------------
OPENAI_API_KEY=sk-...tu_api_key_de_openai

# --- Google Document AI (OCR) ----------------------------
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=id_del_procesador_documentai
GOOGLE_CLOUD_PROJECT_ID=id_de_tu_proyecto_gcp
GOOGLE_CLOUD_LOCATION=eu

# --- Email (SendGrid) ------------------------------------
SENDGRID_API_KEY=SG.tu_api_key_sendgrid
FROM_EMAIL=crm@tuagencia.com

# --- URLs ------------------------------------------------
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000
PORT=3000
